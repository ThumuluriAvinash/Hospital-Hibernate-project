<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
    "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <!-- ============================================ -->
        <!--   DATABASE CONNECTION SETTINGS               -->
        <!-- ============================================ -->

        <!-- JDBC Driver -->
        <property name="hibernate.connection.driver_class">
            com.mysql.cj.jdbc.Driver
        </property>

        <!-- Database URL — change host/port if needed -->
        <property name="hibernate.connection.url">
            jdbc:mysql://localhost:3306/fsadexam?createDatabaseIfNotExist=true&amp;useSSL=false&amp;serverTimezone=UTC
        </property>

        <!-- *** CHANGE these credentials to match your MySQL setup *** -->
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">root</property>

        <!-- ============================================ -->
        <!--   HIBERNATE SETTINGS                         -->
        <!-- ============================================ -->

        <!-- Dialect for MySQL 8 -->
        <property name="hibernate.dialect">
            org.hibernate.dialect.MySQL8Dialect
        </property>

        <!-- Auto-create / update table schema on startup -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Print SQL statements to console -->
        <property name="hibernate.show_sql">true</property>

        <!-- Pretty-print SQL -->
        <property name="hibernate.format_sql">true</property>

        <!-- Connection pool size -->
        <property name="hibernate.connection.pool_size">5</property>

        <!-- ============================================ -->
        <!--   MAPPED ENTITY CLASSES                      -->
        <!-- ============================================ -->
        <mapping class="com.klef.fsad.exam.Hospital"/>

    </session-factory>
</hibernate-configuration>
